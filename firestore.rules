rules_version = '2';

// gang.roll — Firestore security rules
// Model: simple shared album · delete = leave (remove self) · gangs owner-private.
// Hardened after an adversarial review: every event write is now field-scoped
// (join/leave touch only membership; members bump only counters; host edits
// metadata) so a member can't hijack hostId, tamper with other members, or
// rewrite photo identity. VALIDATE with the Firestore emulator before relying
// on these (the membership writes must be implemented to match — see notes).

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid()      { return request.auth.uid; }

    function eventMembers(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data.memberIds;
    }
    function isEventMember(eventId) {
      return signedIn() && uid() in eventMembers(eventId);
    }

    // The film "develop-lock": a roll's photos are readable only once it has
    // developed — i.e. it has no end time (open album) OR the develop time has
    // passed. MUST short-circuit absent/null `endsAt` BEFORE the time compare,
    // or the comparison throws and denies even a developed roll's reads.
    function rollDeveloped(eventId) {
      let e = get(/databases/$(database)/documents/events/$(eventId)).data;
      return !('endsAt' in e) || e.endsAt == null || request.time >= e.endsAt;
    }

    // ---- users -------------------------------------------------------------
    // Profiles are readable by any signed-in user (names/avatars show up in
    // rolls); writable only by their owner.
    match /users/{userId} {
      allow read:           if signedIn();
      allow create, update: if uid() == userId;
      allow delete:         if false;
    }

    // ---- join-code registry ------------------------------------------------
    // codes/{CODE} -> { eventId }. Readable by any signed-in user (to join).
    // Create is allowed ONLY for a code pointing at an already-existing event
    // the caller hosts — blocks code-squatting and malicious code->event
    // mis-mapping. (Impl: write the event first, then create its code.) Never
    // mutated, so a code can't be re-pointed.
    match /codes/{code} {
      allow read:   if signedIn();
      allow create: if signedIn()
        && request.resource.data.eventId is string
        && exists(/databases/$(database)/documents/events/$(request.resource.data.eventId))
        && get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.hostId == uid();
      allow update, delete: if false;
    }

    // ---- events (rolls) ----------------------------------------------------
    match /events/{eventId} {

      function isHost()   { return resource.data.hostId == uid(); }
      function isMember() { return uid() in resource.data.memberIds; }

      // A join/leave write may change ONLY membership fields, and never hostId
      // — stops a joiner from hijacking the roll or overwriting
      // title/cover/counters/other members in the same write.
      function membershipOnlyChange() {
        return request.resource.data.hostId == resource.data.hostId
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['memberIds', 'members', 'memberCount', 'lastActiveAt']);
      }

      // Caller adds ONLY themselves (join). memberIds and members grow by one.
      function onlySelfAdded() {
        return !(uid() in resource.data.memberIds)
          && (uid() in request.resource.data.memberIds)
          && request.resource.data.memberIds.removeAll(resource.data.memberIds).hasOnly([uid()])
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
          && request.resource.data.members.size() == resource.data.members.size() + 1
          && membershipOnlyChange();
      }
      // Caller removes ONLY themselves (leave / delete-from-my-view).
      function onlySelfRemoved() {
        return (uid() in resource.data.memberIds)
          && !(uid() in request.resource.data.memberIds)
          && resource.data.memberIds.removeAll(request.resource.data.memberIds).hasOnly([uid()])
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1
          && request.resource.data.members.size() == resource.data.members.size() - 1
          && membershipOnlyChange();
      }
      // Any member may bump activity counters only — never membership/metadata.
      function onlyCounterBump() {
        return isMember()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['photoCount', 'viewCount', 'lastActiveAt']);
      }

      allow read: if signedIn() && uid() in resource.data.memberIds;

      // Create: caller is host, sole initial member, members[] matches, counters
      // zeroed.
      allow create: if signedIn()
        && request.resource.data.hostId == uid()
        && request.resource.data.memberIds == [uid()]
        && request.resource.data.members.size() == 1
        && request.resource.data.members[0].uid == uid()
        && request.resource.data.members[0].role == 'host'
        && request.resource.data.memberCount == 1
        && request.resource.data.photoCount == 0
        && request.resource.data.viewCount == 0;

      // Update: host edits metadata; a user joins/leaves themselves; or a member
      // bumps activity counters.
      allow update: if signedIn()
        && (isHost() || onlySelfAdded() || onlySelfRemoved() || onlyCounterBump());

      // Hard delete reserved for the host (MVP uses leave; host cleanup later).
      allow delete: if signedIn() && isHost();

      // members subcollection — per-member detail; each member owns their doc
      match /members/{memberId} {
        allow read:                   if isEventMember(eventId);
        allow create, update, delete: if signedIn() && memberId == uid();
      }

      // photos subcollection — metadata only; bytes live in Cloudflare R2.
      // Reads are develop-locked: hidden while the roll is Live, revealed once
      // it develops. Uploads (create) stay allowed while Live so members can
      // still shoot — they just can't view until reveal.
      match /photos/{photoId} {
        allow read:   if isEventMember(eventId) && rollDeveloped(eventId);
        allow create: if isEventMember(eventId)
                      && request.resource.data.uploaderId == uid();
        // Only the favorite flag may flip; uploaderId/url/storageKey are frozen.
        allow update: if isEventMember(eventId)
                      && request.resource.data.uploaderId == resource.data.uploaderId
                      && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['favorite']);
        allow delete: if signedIn() && resource.data.uploaderId == uid();
      }

      // activity subcollection — the in-app feed (stands in for push). Any member
      // reads it; a member may append ONLY their own action (actorId == self).
      // Append-only: entries are never edited or removed.
      match /activity/{activityId} {
        allow read:   if isEventMember(eventId);
        allow create: if isEventMember(eventId)
                      && request.resource.data.actorId == uid();
        allow update, delete: if false;
      }
    }

    // ---- gangs (personal, owner-private) -----------------------------------
    match /gangs/{gangId} {
      allow read, update, delete: if signedIn() && resource.data.ownerId == uid();
      allow create:               if signedIn() && request.resource.data.ownerId == uid();
    }
  }
}
